{
  "manifest_version": 2,
  "name": "Phishing Detector",
  "version": "0.1.0",
  "description": "Local phishing detection for Gmail.",
  "permissions": ["activeTab", "https://mail.google.com/*", "http://localhost:8000/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_title": "Phishing Check",
    "default_popup": "popup.html"
  }
}
